{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bang",
  "scopeName": "source.bang",
  "fileTypes": ["bang"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#builtin" },
    { "include": "#constant" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#operator" },
    { "include": "#punctuation" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.bang",
      "match": "//.*$"
    },
    "string": {
      "name": "string.quoted.double.bang",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.bang",
          "match": "\\\\[\\\\\"ntr0]"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.bang",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.bang",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.bang",
          "match": "\\b(if|else|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.bang",
          "match": "\\b(let|fn)\\b"
        },
        {
          "name": "keyword.operator.logical.bang",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.concurrency.bang",
          "match": "\\b(spawn|parallel)\\b"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.boolean.bang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.bang",
          "match": "\\bnil\\b"
        }
      ]
    },
    "builtin": {
      "name": "support.function.builtin.bang",
      "match": "\\b(print|len|str|int|float|bool|type|assert|exit|channel|send|recv|close|wait|parallel_map|keys|values|push|pop|contains|abs|sqrt|floor|ceil|round|pow|min|max)\\b(?=\\s*\\()"
    },
    "function-def": {
      "patterns": [
        {
          "comment": "fn name(params)",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.bang" },
            "2": { "name": "entity.name.function.bang" }
          }
        },
        {
          "comment": "let name = fn(...)",
          "match": "\\b(let)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*(?=fn\\b)",
          "captures": {
            "1": { "name": "keyword.declaration.bang" },
            "2": { "name": "entity.name.function.bang" }
          }
        }
      ]
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.bang" }
      }
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.bang",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.bang",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.bang",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.bang",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.bang",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.bang",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.bang",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.bang",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.bang",
          "match": "\\)"
        },
        {
          "name": "punctuation.separator.comma.bang",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.bang",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.bang",
          "match": "\\."
        }
      ]
    },
    "identifier": {
      "name": "variable.other.bang",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
